---
import Layout from "../layouts/Layout.astro";
import Stamp from "../components/Stamp.astro";
---

<Layout title="404 — mojiemoji" description="ページが見つかりませんでした。">
  <main class="bg-grid flex min-h-screen flex-col items-center justify-center px-5 text-center">
    <p class="font-display text-7xl font-bold text-white/15 sm:text-8xl">404</p>
    <h1 class="mt-4 flex items-center justify-center gap-2 font-display text-2xl font-bold text-paper sm:text-3xl">
      <Stamp text="迷子" font="hachimaru" color="f472b6" animation="yurayura" height={36} class="h-9 w-auto" />
      になりました
    </h1>
    <p class="mt-3 text-sm text-muted">お探しのページは見つかりませんでした。</p>
    <a
      href="/"
      class="mt-8 inline-flex cursor-pointer items-center justify-center rounded-xl bg-run px-6 py-3 text-sm font-bold text-ink shadow-lg shadow-run/20 transition-colors duration-200 hover:bg-run-bright"
    >
      ホームに戻る
    </a>
  </main>
</Layout>
