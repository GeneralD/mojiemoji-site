---
import Stamp from "./Stamp.astro";

const features = [
  {
    title: "キーワードだけを自動置換",
    body: "文章はそのまま。文中の効かせたい語だけを mid-sentence でスタンプ化。読みやすさを壊さず、印象だけを足します。",
    color: "text-brand-purple",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z" />`,
  },
  {
    title: "16 フォント × 34 アニメ",
    body: "丸ゴシックから手書き・ピクセル・とげとげまで 16 書体、ぷよん・きらり・集中線など 34 種の動き。組み合わせは膨大です。",
    color: "text-brand-cyan",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 0 0 5.304 0l6.401-6.402M6.75 21A3.75 3.75 0 0 1 3 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 0 0 3.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.439-.439 1.151-.439 1.59 0l3.712 3.713c.439.44.439 1.151 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008Z" />`,
  },
  {
    title: "Unicode 絵文字も動く",
    body: "🎉 ⚠️ ✅ ❌ などカタログ登録済みの絵文字 162 種は、手書き URL なしで自動的にアニメ &lt;img&gt; へ。連続絵文字は 2 連までガード。",
    color: "text-brand-pink",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 0 1-6.364 0M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0ZM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75Zm-.375 0h.008v.008h-.008V9.75Zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75Zm-.375 0h.008v.008h-.008V9.75Z" />`,
  },
  {
    title: "GitHub の全 surface 対応",
    body: "issue・PR・コードレビュー・リプライ・リリースノート。surface ごとの配置ポリシーで、過剰にならない密度に整えます。",
    color: "text-run-bright",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="m14.25 9.75 2.25 2.25-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0 0 20.25 18V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v12A2.25 2.25 0 0 0 6 20.25Z" />`,
  },
  {
    title: "Claude Code プラグインで全自動",
    body: "プラグインを入れれば、面倒な装飾は AI が代行。プレーンに書いた本文へ、適切なフォント・色・動きが自動で乗ります。",
    color: "text-amber-300",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />`,
  },
  {
    title: "正体はただの &lt;img&gt;",
    body: "出力は素の画像タグ。JavaScript も登録もビルドも不要で、GitHub Markdown が描ける場所ならどこでも動きます。",
    color: "text-sky-300",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />`,
  },
];
---

<section id="features" class="mx-auto max-w-6xl px-5 py-20 sm:py-28">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="font-display text-3xl font-bold tracking-tight text-paper sm:text-4xl">
      書くだけで、
      <Stamp text="豊か" font="maru-bold" color="4ade80" animation="mochimochi" outline="804ade" height={34} class="h-7 w-auto sm:h-9" />
      に。
    </h2>
    <p class="mt-4 text-base text-muted sm:text-lg">
      装飾の手間を全部引き受ける、6 つの仕組み。
    </p>
  </div>

  <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {
      features.map((f) => (
        <article class="group rounded-2xl border border-white/10 bg-panel/50 p-6 transition-colors duration-200 hover:border-white/20 hover:bg-panel">
          <div class={`mb-4 inline-flex rounded-xl border border-white/10 bg-ink/60 p-3 ${f.color}`}>
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <Fragment set:html={f.icon} />
            </svg>
          </div>
          <h3 class="font-display text-lg font-bold text-paper" set:html={f.title} />
          <p class="mt-2 text-sm leading-relaxed text-muted" set:html={f.body} />
        </article>
      ))
    }
  </div>
</section>
