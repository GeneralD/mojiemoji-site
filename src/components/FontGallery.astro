---
import Stamp from "./Stamp.astro";

// All 16 canonical fonts, same word + calm animation so only the typeface varies.
// NOTE: the service applies fonts to hiragana/katakana but NOT kanji yet, so the
// sample must be hiragana — a kanji sample would render identically across all 16.
const fonts = [
  "gothic", "gothic-bold", "maru", "maru-bold",
  "mincho", "dela", "akzk", "zero",
  "kurobara", "hachimaru", "chikara", "tamanegi",
  "pixel", "toge", "rampart", "noto",
];
---

<section id="fonts" class="mx-auto max-w-6xl px-5 py-20 sm:py-28">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="font-display text-3xl font-bold tracking-tight text-paper sm:text-4xl">
      <span class="text-gradient">16</span> の書体
    </h2>
    <p class="mt-4 text-base text-muted sm:text-lg">
      同じ「もじ」も、書体が変われば気分が変わる。丸ゴ・明朝・手書き・ピクセルまで。
    </p>
  </div>

  <div class="mt-12 grid grid-cols-2 gap-3 sm:grid-cols-4">
    {
      fonts.map((font) => (
        <div class="flex flex-col items-center justify-center gap-3 rounded-xl border border-white/10 bg-panel/50 px-3 py-6 transition-colors duration-200 hover:border-white/20 hover:bg-panel">
          <Stamp text="もじ" font={font} color="c084fc" animation="yurayura" height={40} class="h-10 w-auto" />
          <code class="text-xs text-muted">{font}</code>
        </div>
      ))
    }
  </div>
</section>
