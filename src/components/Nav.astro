---
import Stamp from "./Stamp.astro";

const SERVICE_URL = "https://mojiemoji.jozo.beer";
const REPO_URL = "https://github.com/jozobeer/mojiemoji-plugin";

const links = [
  { href: "#demo", label: "デモ" },
  { href: "#features", label: "特徴" },
  { href: "#fonts", label: "フォント" },
  { href: "#animations", label: "アニメ" },
  { href: "#plugin", label: "プラグイン" },
];
---

<header class="fixed inset-x-0 top-0 z-50 px-4 pt-4">
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 rounded-2xl border border-white/10 bg-panel/70 px-4 py-2.5 backdrop-blur-md sm:px-6"
  >
    <a href="#top" class="flex items-center gap-2" aria-label="mojiemoji ホーム">
      <Stamp text="もじ" font="rampart" color="f472b6" animation="poyoon" height={30} eager={true} />
      <span class="font-display text-lg font-bold tracking-tight text-paper">mojiemoji</span>
    </a>

    <ul class="hidden items-center gap-7 text-sm font-medium text-muted md:flex">
      {
        links.map((l) => (
          <li>
            <a class="transition-colors duration-200 hover:text-paper" href={l.href}>
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-2">
      <a
        href={REPO_URL}
        target="_blank"
        rel="noopener"
        class="hidden cursor-pointer rounded-lg px-3 py-2 text-sm font-semibold text-muted transition-colors duration-200 hover:text-paper sm:inline-block"
      >
        GitHub
      </a>
      <a
        href={SERVICE_URL}
        target="_blank"
        rel="noopener"
        class="cursor-pointer rounded-lg bg-run px-4 py-2 text-sm font-bold text-ink shadow-lg shadow-run/20 transition-colors duration-200 hover:bg-run-bright"
      >
        今すぐ試す
      </a>
    </div>
  </nav>
</header>
